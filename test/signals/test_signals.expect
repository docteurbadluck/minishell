#!/usr/bin/expect

log_user 1
set timeout 5
set MINISHELL [lindex $argv 0]
set PROMPT "> "

proc run_test {name body} {
    global MINISHELL PROMPT
    puts "\n=== $name ==="
    if {[catch $body err]} {
        puts "✗ $name : ERREUR ($err)"
    }
}

# --- TEST 1 : SIGINT au menu ---
run_test "TEST 1 : SIGINT au menu" {
    spawn $MINISHELL
    expect $PROMPT
    send "\x03"
    expect {
        $PROMPT { puts "✓ SIGINT au menu : OK" }
        timeout { puts "✗ SIGINT au menu : TIMEOUT" }
        eof     { puts "✗ SIGINT au menu : minishell a quitte" }
    }
    send "exit\n"
    wait
}

# --- TEST 2 : SIGINT pendant sleep ---
run_test "TEST 2 : SIGINT pendant sleep 5" {
    spawn $MINISHELL
    expect $PROMPT
    send "sleep 5\n"
    sleep 1
    send "\x03"
    expect {
        $PROMPT { puts "✓ SIGINT pendant sleep : OK" }
        timeout { puts "✗ SIGINT pendant sleep : TIMEOUT" }
        eof     { puts "✗ SIGINT pendant sleep : minishell a quitte" }
    }
    send "exit\n"
    wait
}

# --- TEST 3 : SIGQUIT pendant sleep ---
run_test "TEST 3 : SIGQUIT pendant sleep 5" {
    spawn $MINISHELL
    expect $PROMPT
    send "sleep 5\n"
    sleep 1
    send "\x1c"
    expect {
        $PROMPT { puts "✓ SIGQUIT pendant sleep : OK" }
        timeout { puts "✗ SIGQUIT pendant sleep : TIMEOUT" }
        eof     { puts "✗ SIGQUIT pendant sleep : minishell a quitte" }
    }
    send "exit\n"
    wait
}

# --- TEST 4 : SIGINT pendant heredoc ---
run_test "TEST 4 : SIGINT pendant heredoc" {
    spawn $MINISHELL
    expect $PROMPT
    send "cat << EOF\n"
    expect {
        ">"     {}
        timeout { puts "✗ heredoc : prompt > non apparu"; return }
        eof     { puts "✗ heredoc : minishell a quitte"; return }
    }
    sleep 0.5
    send "\x03"
    expect {
        $PROMPT { puts "✓ SIGINT pendant heredoc : OK" }
        timeout { puts "✗ SIGINT pendant heredoc : TIMEOUT" }
        eof     { puts "✗ SIGINT pendant heredoc : minishell a quitte" }
    }
    send "exit\n"
    wait
}

run_test "TEST 5 : ctrl +D pendant heredoc" {
    spawn $MINISHELL
    expect $PROMPT
    send "cat << eof\n"
    expect {
        ">" {}
        timeout {puts " x heredoc : nothing happened"; return}
        eof { puts "✗ heredoc : minishell a quitte"; return }
    }
    sleep 0.5
    send "\x04"
    expect {
        $PROMPT { puts "✓ eof pendant heredoc : OK" }
        timeout { puts "✗ eof pendant heredoc : TIMEOUT" }
        eof     { puts "✗ eof pendant heredoc : minishell a quitte" }
    }
    send "exit\n"
    wait
}


# --- TEST 6 : CTRL+D au menu → minishell doit quitter ---
run_test "TEST 6 : ctrl+D au menu" {
    spawn $MINISHELL
    expect $PROMPT
    send "\x04"
    expect {
        eof     { puts "✓ ctrl+D au menu : minishell a quitte" }
        timeout { puts "✗ ctrl+D au menu : minishell n'a pas quitte" }
    }
    wait
}

# --- TEST 7 : CTRL+D pendant `cat` → EOF envoyé à cat, minishell revient au prompt ---
run_test "TEST 7 : ctrl+D pendant cat" {
    spawn $MINISHELL
    expect $PROMPT
    send "cat\n"
    sleep 0.5
    send "\x04"
    expect {
        $PROMPT { puts "✓ ctrl+D pendant cat : retour au prompt" }
        timeout { puts "✗ ctrl+D pendant cat : TIMEOUT" }
        eof     { puts "✗ ctrl+D pendant cat : minishell a quitte" }
    }
    send "exit\n"
    wait
}

# --- TEST 8 : heredoc
run_test "TEST 8 : heredoc normal" {
    spawn $MINISHELL
    expect $PROMPT
    send "cat << eof\n"
    expect {
        ">"     {}
        timeout { puts "✗ heredoc : prompt > non apparu"; return }
        eof     { puts "✗ heredoc : minishell a quitte"; return }
    }
    send "hello world\n"
    send "eof\n"
    expect {
        "hello world" { puts "✓ heredoc normal : OK" }
        timeout { puts "✗ heredoc normal : TIMEOUT" }
        eof     { puts "✗ heredoc normal : minishell a quitte" }
    }
    expect $PROMPT
    send "exit\n"
    wait
}

# --- TEST 9 : heredoc multi-lignes
run_test "TEST 9 : heredoc multi-lignes" {
    spawn $MINISHELL
    expect $PROMPT
    send "cat << eof\n"
    expect {
        ">"     {}
        timeout { puts "✗ heredoc multi : prompt > non apparu"; return }
        eof     { puts "✗ heredoc multi : minishell a quitte"; return }
    }
    send "line one\n"
    send "line two\n"
    send "eof\n"
    expect {
        "line one" { puts "✓ heredoc multi-lignes : OK" }
        timeout    { puts "✗ heredoc multi-lignes : TIMEOUT" }
        eof        { puts "✗ heredoc multi-lignes : minishell a quitte" }
    }
    expect $PROMPT
    send "exit\n"
    wait
}

# --- TEST 10 : heredoc expansion de variable
run_test "TEST 10 : heredoc expansion variable" {
    spawn $MINISHELL
    expect $PROMPT
    send "cat << eof\n"
    expect {
        ">"     {}
        timeout { puts "✗ heredoc expand : prompt > non apparu"; return }
        eof     { puts "✗ heredoc expand : minishell a quitte"; return }
    }
    send "home is \$HOME\n"
    send "eof\n"
    expect {
        "home is /" { puts "✓ heredoc expansion variable : OK" }
        timeout     { puts "✗ heredoc expansion variable : TIMEOUT" }
        eof         { puts "✗ heredoc expansion variable : minishell a quitte" }
    }
    expect $PROMPT
    send "exit\n"
    wait
}

# --- TEST 11 : heredoc sans expansion (delimiter quote)
run_test "TEST 11 : heredoc sans expansion" {
    spawn $MINISHELL
    expect $PROMPT
    send "cat << 'eof'\n"
    expect {
        ">"     {}
        timeout { puts "✗ heredoc no expand : prompt > non apparu"; return }
        eof     { puts "✗ heredoc no expand : minishell a quitte"; return }
    }
    send "\$HOME\n"
    send "eof\n"
    expect {
        "\$HOME" { puts "✓ heredoc sans expansion : OK" }
        timeout  { puts "✗ heredoc sans expansion : TIMEOUT" }
        eof      { puts "✗ heredoc sans expansion : minishell a quitte" }
    }
    expect $PROMPT
    send "exit\n"
    wait
}

# --- TEST 12 : heredoc vide
run_test "TEST 12 : heredoc vide" {
    spawn $MINISHELL
    expect $PROMPT
    send "cat << eof\n"
    expect {
        ">"     {}
        timeout { puts "✗ heredoc vide : prompt > non apparu"; return }
        eof     { puts "✗ heredoc vide : minishell a quitte"; return }
    }
    send "eof\n"
    expect {
        $PROMPT { puts "✓ heredoc vide : OK" }
        timeout { puts "✗ heredoc vide : TIMEOUT" }
        eof     { puts "✗ heredoc vide : minishell a quitte" }
    }
    send "exit\n"
    wait
}

puts "\n=== DONE ==="
